<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="SocialPrepTool.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:SocialPrepTool"
    xmlns:models="using:SocialPrepTool.Models"
    xmlns:viewmodels="using:SocialPrepTool.ViewModels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:skia="using:SkiaSharp.Views.Windows"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <local:StringHexToColorConverter x:Key="ColorConverter" />
        <local:ProcessingVisibilityConverter x:Key="ProcessingVisibilityConverter" />
        <local:DoneVisibilityConverter x:Key="DoneVisibilityConverter" />
        <local:ErrorVisibilityConverter x:Key="ErrorVisibilityConverter" />
        <local:PresetModeVisibilityConverter x:Key="PresetModeConverter" />
        <local:StringHexToBrushConverter x:Key="BrushConverter" />

        <!-- Modern Hover & Scale Style for Color Swatches -->
        <Style x:Key="ColorSwatchButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinWidth" Value="32"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="RootGrid" Background="Transparent" CornerRadius="16">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ScaleTransform" Storyboard.TargetProperty="ScaleX" To="1.2" Duration="0:0:0.1" />
                                            <DoubleAnimation Storyboard.TargetName="ScaleTransform" Storyboard.TargetProperty="ScaleY" To="1.2" Duration="0:0:0.1" />
                                            <DoubleAnimation Storyboard.TargetName="HoverOverlay" Storyboard.TargetProperty="Opacity" To="0.1" Duration="0:0:0.1" />
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ScaleTransform" Storyboard.TargetProperty="ScaleX" To="0.9" Duration="0:0:0.05" />
                                            <DoubleAnimation Storyboard.TargetName="ScaleTransform" Storyboard.TargetProperty="ScaleY" To="0.9" Duration="0:0:0.05" />
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="Opacity" To="0.5" Duration="0" />
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Grid.RenderTransform>
                                <ScaleTransform x:Name="ScaleTransform" CenterX="16" CenterY="16" />
                            </Grid.RenderTransform>
                            <ContentPresenter x:Name="Content" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <Ellipse x:Name="HoverOverlay" Width="28" Height="28" Fill="White" Opacity="0" IsHitTestVisible="False"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Hover & Scale Style for Toolbar & Template Icon Buttons -->
        <Style x:Key="ToolbarIconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="MinWidth" Value="32"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="RootGrid" Background="Transparent" CornerRadius="{TemplateBinding CornerRadius}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="BackgroundHover" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.1" />
                                            <DoubleAnimation Storyboard.TargetName="ScaleTransform" Storyboard.TargetProperty="ScaleX" To="1.1" Duration="0:0:0.1" />
                                            <DoubleAnimation Storyboard.TargetName="ScaleTransform" Storyboard.TargetProperty="ScaleY" To="1.1" Duration="0:0:0.1" />
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="BackgroundHover" Storyboard.TargetProperty="Opacity" To="0.8" Duration="0" />
                                            <DoubleAnimation Storyboard.TargetName="ScaleTransform" Storyboard.TargetProperty="ScaleX" To="0.9" Duration="0:0:0.05" />
                                            <DoubleAnimation Storyboard.TargetName="ScaleTransform" Storyboard.TargetProperty="ScaleY" To="0.9" Duration="0:0:0.05" />
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="Opacity" To="0.4" Duration="0" />
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Grid.RenderTransform>
                                <ScaleTransform x:Name="ScaleTransform" CenterX="16" CenterY="16" />
                            </Grid.RenderTransform>
                            <Border x:Name="BackgroundHover" Background="{ThemeResource ButtonBackgroundPointerOver}" CornerRadius="{TemplateBinding CornerRadius}" Opacity="0" />
                            <ContentPresenter x:Name="Content" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}" Margin="{TemplateBinding Padding}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid ColumnSpacing="16" RowSpacing="16" Padding="16">
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="Delete" Invoked="DeleteAccelerator_Invoked" />
            <KeyboardAccelerator Key="E" Modifiers="Control" Invoked="ExportAccelerator_Invoked" />
        </Grid.KeyboardAccelerators>

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="76" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>

        <!-- Queue Panel (Left) -->
        <Grid Grid.Row="0" Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="16" AllowDrop="True" DragOver="QueuePanel_DragOver" Drop="QueuePanel_Drop">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Queue" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Grid.Column="1" Click="ImportPhotos_Click" Padding="12,6" CornerRadius="6" ToolTipService.ToolTip="Import image files (Drag-and-Drop is also supported)">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE8B5;" FontSize="14" />
                        <TextBlock Text="Import" FontSize="13" />
                    </StackPanel>
                </Button>
            </Grid>

            <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.QueueItems, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedQueueItem, Mode=TwoWay}" CanDragItems="True" CanReorderItems="True" AllowDrop="True">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="viewmodels:QueueItem">
                        <Grid Margin="0,4" Padding="8" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="6" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <CheckBox Grid.Column="0" IsChecked="{x:Bind IsChecked, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,6,0" />

                            <Border Grid.Column="1" Width="56" Height="56" CornerRadius="6" Background="{ThemeResource ControlFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" VerticalAlignment="Center" Margin="0,0,8,0">
                                <Grid>
                                    <FontIcon Glyph="&#xE114;" FontSize="18" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Visibility="{x:Bind PlaceholderVisibility, Mode=OneWay}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    <Border CornerRadius="6" Visibility="{x:Bind ThumbnailVisibility, Mode=OneWay}">
                                        <Border.Background>
                                            <ImageBrush ImageSource="{x:Bind Thumbnail, Mode=OneWay}" Stretch="UniformToFill" />
                                        </Border.Background>
                                    </Border>
                                </Grid>
                            </Border>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind TruncatedFileName, Mode=OneWay}" FontWeight="SemiBold" FontSize="13" ToolTipService.ToolTip="{x:Bind FileName}" />

                                <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,4,0,0">
                                    <Border Background="{ThemeResource SystemAccentColor}" CornerRadius="4" Padding="5,2" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Record.TargetRatio, Mode=OneWay}" FontSize="9" FontWeight="SemiBold" Foreground="White" />
                                    </Border>



                                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" Margin="4,0,0,0">
                                        <ProgressRing IsActive="True" Width="12" Height="12" Visibility="{x:Bind Status, Converter={StaticResource ProcessingVisibilityConverter}, Mode=OneWay}" />
                                        <FontIcon Glyph="&#xE73E;" FontSize="12" Foreground="{ThemeResource SystemFillColorSuccessBrush}" Visibility="{x:Bind Status, Converter={StaticResource DoneVisibilityConverter}, Mode=OneWay}" />
                                        <FontIcon Glyph="&#xEA39;" FontSize="12" Foreground="{ThemeResource SystemFillColorCriticalBrush}" Visibility="{x:Bind Status, Converter={StaticResource ErrorVisibilityConverter}, Mode=OneWay}" ToolTipService.ToolTip="{x:Bind ErrorMessage, Mode=OneWay}" />
                                        <TextBlock Text="{x:Bind Status, Mode=OneWay}" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- Preview Canvas (Center) -->
        <Grid Grid.Row="0" Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
            <skia:SKXamlCanvas x:Name="PreviewCanvas" PaintSurface="PreviewCanvas_PaintSurface" />

            <!-- Info Badge (Top Right) -->
            <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="12" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}" CornerRadius="6" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="8,4">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE7b4;" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                    <TextBlock x:Name="ImageInfoText" Text="Resolution" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Zoom Badge (Bottom Left) -->
            <Border HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="12" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}" CornerRadius="6" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="8,4">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE71E;" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                    <TextBlock x:Name="ZoomInfoText" Text="Fit" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Preset Sidebar (Right) -->
        <Grid Grid.Row="0" Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Presets" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Grid.Column="1" Style="{ThemeResource AccentButtonStyle}" Click="NewPreset_Click" Padding="12,6" CornerRadius="6" ToolTipService.ToolTip="Save current edit settings as a new preset">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE109;" FontSize="12" />
                        <TextBlock Text="New" FontSize="13" />
                    </StackPanel>
                </Button>
            </Grid>

            <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.PresetContainer.Presets, Mode=OneWay}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:Preset">
                        <Grid Margin="0,4" Padding="12" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="6" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0" Width="28" Height="28" Margin="0,0,12,0" VerticalAlignment="Center">
                                <!-- Solid color swatch -->
                                <Ellipse Width="28" Height="28" Stroke="{ThemeResource DividerStrokeColorDefaultBrush}" StrokeThickness="1" Fill="{x:Bind BackgroundColor, Converter={StaticResource BrushConverter}}" Visibility="{x:Bind BackgroundMode, Converter={StaticResource PresetModeConverter}, ConverterParameter=solid, Mode=OneWay}" />
                                <!-- Blur representation (nice blue/purple gradient) -->
                                <Ellipse Width="28" Height="28" Stroke="{ThemeResource DividerStrokeColorDefaultBrush}" StrokeThickness="1" Visibility="{x:Bind BackgroundMode, Converter={StaticResource PresetModeConverter}, ConverterParameter=blur, Mode=OneWay}">
                                    <Ellipse.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FF0078D4" Offset="0.0" />
                                            <GradientStop Color="#FF8E44AD" Offset="1.0" />
                                        </LinearGradientBrush>
                                    </Ellipse.Fill>
                                </Ellipse>
                            </Grid>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" FontSize="13" />
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                    <Border Background="{ThemeResource SystemAccentColor}" CornerRadius="4" Padding="4,2">
                                        <TextBlock Text="{x:Bind TargetRatio}" FontSize="9" FontWeight="SemiBold" Foreground="White" />
                                    </Border>
                                    <TextBlock Text="{x:Bind BackgroundMode}" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="4">
                                <Button Style="{StaticResource ToolbarIconButtonStyle}" Click="ApplyPreset_Click" Tag="{x:Bind}" ToolTipService.ToolTip="Apply preset to selected item">
                                    <FontIcon Glyph="&#xE8FB;" FontSize="12" Foreground="{ThemeResource SystemAccentColor}" />
                                </Button>
                                <Button Style="{StaticResource ToolbarIconButtonStyle}" Click="DeletePreset_Click" Tag="{x:Bind}" ToolTipService.ToolTip="Delete Preset">
                                    <FontIcon Glyph="&#xE107;" FontSize="12" Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                                </Button>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12" Visibility="{x:Bind IsEmpty(ViewModel.PresetContainer.Presets.Count), Mode=OneWay}">
                <FontIcon Glyph="&#xE81C;" FontSize="36" Foreground="{ThemeResource TextFillColorDisabledBrush}"/>
                <TextBlock Text="No presets saved yet." Foreground="{ThemeResource TextFillColorDisabledBrush}" FontSize="13" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Bottom Bar -->
        <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal" Spacing="24" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Ratio" VerticalAlignment="Center" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontWeight="SemiBold" />
                        <ComboBox SelectedItem="{x:Bind ViewModel.SelectedQueueItem.Record.TargetRatio, Mode=TwoWay}" Width="100" CornerRadius="6">
                            <x:String>1:1</x:String>
                            <x:String>4:5</x:String>
                            <x:String>16:9</x:String>
                            <x:String>9:16</x:String>
                        </ComboBox>
                    </StackPanel>

                    <Border Width="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Height="28" VerticalAlignment="Center" />

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Background" VerticalAlignment="Center" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontWeight="SemiBold" />
                        <ComboBox SelectedItem="{x:Bind ViewModel.SelectedQueueItem.Record.BackgroundMode, Mode=TwoWay}" Width="100" CornerRadius="6">
                            <x:String>blur</x:String>
                            <x:String>solid</x:String>
                        </ComboBox>
                    </StackPanel>

                    <!-- Blur Control (Contextual) -->
                    <StackPanel Orientation="Horizontal" Spacing="8" Visibility="{x:Bind IsBlurMode(ViewModel.SelectedQueueItem.Record.BackgroundMode), Mode=OneWay}">
                        <TextBlock Text="Blur Strength" VerticalAlignment="Center" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontWeight="SemiBold" />
                        <Slider Minimum="0" Maximum="100" Value="{x:Bind ViewModel.SelectedQueueItem.Record.BlurStrength, Mode=TwoWay}" Width="120" VerticalAlignment="Center" Margin="0,4,0,0" />
                    </StackPanel>

                    <!-- Color Control (Contextual) -->
                    <StackPanel Orientation="Horizontal" Spacing="8" Visibility="{x:Bind IsSolidMode(ViewModel.SelectedQueueItem.Record.BackgroundMode), Mode=OneWay}">
                        <TextBlock Text="Color" VerticalAlignment="Center" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                            <Button Style="{StaticResource ColorSwatchButtonStyle}" Click="PredefinedColor_Click" Tag="#FFFFFF" ToolTipService.ToolTip="White (#FFFFFF)">
                                <Ellipse Width="24" Height="24" Fill="#FFFFFF" Stroke="{x:Bind GetColorSwatchStroke('#FFFFFF', ViewModel.SelectedQueueItem.Record.BackgroundColor), Mode=OneWay}" StrokeThickness="{x:Bind GetColorSwatchThickness('#FFFFFF', ViewModel.SelectedQueueItem.Record.BackgroundColor), Mode=OneWay}"/>
                            </Button>
                            <Button Style="{StaticResource ColorSwatchButtonStyle}" Click="PredefinedColor_Click" Tag="#F8F8F8" ToolTipService.ToolTip="Light Gray (#F8F8F8)">
                                <Ellipse Width="24" Height="24" Fill="#F8F8F8" Stroke="{x:Bind GetColorSwatchStroke('#F8F8F8', ViewModel.SelectedQueueItem.Record.BackgroundColor), Mode=OneWay}" StrokeThickness="{x:Bind GetColorSwatchThickness('#F8F8F8', ViewModel.SelectedQueueItem.Record.BackgroundColor), Mode=OneWay}"/>
                            </Button>
                            <Button Style="{StaticResource ColorSwatchButtonStyle}" Click="PredefinedColor_Click" Tag="#F5F5DC" ToolTipService.ToolTip="Beige (#F5F5DC)">
                                <Ellipse Width="24" Height="24" Fill="#F5F5DC" Stroke="{x:Bind GetColorSwatchStroke('#F5F5DC', ViewModel.SelectedQueueItem.Record.BackgroundColor), Mode=OneWay}" StrokeThickness="{x:Bind GetColorSwatchThickness('#F5F5DC', ViewModel.SelectedQueueItem.Record.BackgroundColor), Mode=OneWay}"/>
                            </Button>
                            <Button Style="{StaticResource ColorSwatchButtonStyle}" Click="PredefinedColor_Click" Tag="#E0E0E0" ToolTipService.ToolTip="Medium Gray (#E0E0E0)">
                                <Ellipse Width="24" Height="24" Fill="#E0E0E0" Stroke="{x:Bind GetColorSwatchStroke('#E0E0E0', ViewModel.SelectedQueueItem.Record.BackgroundColor), Mode=OneWay}" StrokeThickness="{x:Bind GetColorSwatchThickness('#E0E0E0', ViewModel.SelectedQueueItem.Record.BackgroundColor), Mode=OneWay}"/>
                            </Button>
                            <Button Style="{StaticResource ColorSwatchButtonStyle}" Click="PredefinedColor_Click" Tag="#8B8A87" ToolTipService.ToolTip="Warm Gray (#8B8A87)">
                                <Ellipse Width="24" Height="24" Fill="#8B8A87" Stroke="{x:Bind GetColorSwatchStroke('#8B8A87', ViewModel.SelectedQueueItem.Record.BackgroundColor), Mode=OneWay}" StrokeThickness="{x:Bind GetColorSwatchThickness('#8B8A87', ViewModel.SelectedQueueItem.Record.BackgroundColor), Mode=OneWay}"/>
                            </Button>
                            <Button Style="{StaticResource ColorSwatchButtonStyle}" Click="PredefinedColor_Click" Tag="#85929E" ToolTipService.ToolTip="Steel Blue (#85929E)">
                                <Ellipse Width="24" Height="24" Fill="#85929E" Stroke="{x:Bind GetColorSwatchStroke('#85929E', ViewModel.SelectedQueueItem.Record.BackgroundColor), Mode=OneWay}" StrokeThickness="{x:Bind GetColorSwatchThickness('#85929E', ViewModel.SelectedQueueItem.Record.BackgroundColor), Mode=OneWay}"/>
                            </Button>
                            <Button Style="{StaticResource ColorSwatchButtonStyle}" Click="PredefinedColor_Click" Tag="#2C3E50" ToolTipService.ToolTip="Midnight Blue (#2C3E50)">
                                <Ellipse Width="24" Height="24" Fill="#2C3E50" Stroke="{x:Bind GetColorSwatchStroke('#2C3E50', ViewModel.SelectedQueueItem.Record.BackgroundColor), Mode=OneWay}" StrokeThickness="{x:Bind GetColorSwatchThickness('#2C3E50', ViewModel.SelectedQueueItem.Record.BackgroundColor), Mode=OneWay}"/>
                            </Button>
                            <Button Style="{StaticResource ColorSwatchButtonStyle}" Click="PredefinedColor_Click" Tag="#2A2A2A" ToolTipService.ToolTip="Dark Gray (#2A2A2A)">
                                <Ellipse Width="24" Height="24" Fill="#2A2A2A" Stroke="{x:Bind GetColorSwatchStroke('#2A2A2A', ViewModel.SelectedQueueItem.Record.BackgroundColor), Mode=OneWay}" StrokeThickness="{x:Bind GetColorSwatchThickness('#2A2A2A', ViewModel.SelectedQueueItem.Record.BackgroundColor), Mode=OneWay}"/>
                            </Button>
                            <Button Style="{StaticResource ColorSwatchButtonStyle}" Click="PredefinedColor_Click" Tag="#1A1A1A" ToolTipService.ToolTip="Very Dark Gray (#1A1A1A)">
                                <Ellipse Width="24" Height="24" Fill="#1A1A1A" Stroke="{x:Bind GetColorSwatchStroke('#1A1A1A', ViewModel.SelectedQueueItem.Record.BackgroundColor), Mode=OneWay}" StrokeThickness="{x:Bind GetColorSwatchThickness('#1A1A1A', ViewModel.SelectedQueueItem.Record.BackgroundColor), Mode=OneWay}"/>
                            </Button>
                            <Button Style="{StaticResource ColorSwatchButtonStyle}" Click="PredefinedColor_Click" Tag="#000000" ToolTipService.ToolTip="Black (#000000)">
                                <Ellipse Width="24" Height="24" Fill="#000000" Stroke="{x:Bind GetColorSwatchStroke('#000000', ViewModel.SelectedQueueItem.Record.BackgroundColor), Mode=OneWay}" StrokeThickness="{x:Bind GetColorSwatchThickness('#000000', ViewModel.SelectedQueueItem.Record.BackgroundColor), Mode=OneWay}"/>
                            </Button>

                            <DropDownButton Margin="6,0,0,0" Padding="10,6" VerticalAlignment="Center" CornerRadius="6" ToolTipService.ToolTip="Choose custom color">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE790;" FontSize="12" />
                                    <TextBlock Text="Custom" FontSize="13" />
                                </StackPanel>
                                <DropDownButton.Flyout>
                                    <Flyout>
                                        <ColorPicker Color="{x:Bind ViewModel.SelectedQueueItem.Record.BackgroundColor, Mode=TwoWay, Converter={StaticResource ColorConverter}}" IsAlphaEnabled="True" IsColorChannelTextInputVisible="True" IsHexInputVisible="True" />
                                    </Flyout>
                                </DropDownButton.Flyout>
                            </DropDownButton>
                            <TextBlock Text="{x:Bind ViewModel.SelectedQueueItem.Record.BackgroundColor, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0" FontWeight="SemiBold" />
                        </StackPanel>
                    </StackPanel>



                    <Border Width="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Height="28" VerticalAlignment="Center" />

                    <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                        <CheckBox Content="Safe Zone" IsChecked="{x:Bind ViewModel.SelectedQueueItem.Record.SafeZoneOverlay, Mode=TwoWay}" Height="32" VerticalAlignment="Center" />
                        <CheckBox Content="Drop Shadow" IsChecked="{x:Bind ViewModel.SelectedQueueItem.Record.DropShadow, Mode=TwoWay}" Height="32" VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center" Margin="16,0,0,0">
                <Button Click="ApplyToAll_Click" Padding="16,8" CornerRadius="6" ToolTipService.ToolTip="Apply current settings to all items in queue">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE14E;" FontSize="14" />
                        <TextBlock Text="Apply to All" FontSize="13" />
                    </StackPanel>
                </Button>

                <Button Style="{ThemeResource AccentButtonStyle}" Click="ExportSelected_Click" IsEnabled="{x:Bind ViewModel.HasCheckedItems, Mode=OneWay}" Padding="16,8" CornerRadius="6" ToolTipService.ToolTip="Export all checked items">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE105;" FontSize="14" />
                        <TextBlock Text="Export Selected" FontSize="13" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
